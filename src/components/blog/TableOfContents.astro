---
import type { MarkdownHeading } from 'astro';

export interface Props {
  headings?: MarkdownHeading[];
}

const { headings = [] } = Astro.props;
const items = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const isVisible = items.length > 1;
---

{
  isVisible && (
    <aside class="hidden w-64 xl:block" aria-label="Article navigation">
      <nav class="sticky top-28 max-h-[calc(100dvh-8rem)] overflow-y-auto border-l border-slate-200 pl-5 text-sm dark:border-slate-800">
        <p class="font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">On this page</p>
        <ol class="mt-3 space-y-1">
          {items.map((heading) => (
            <li class:list={[heading.depth === 3 && 'pl-4']}>
              <a
                class="article-toc-link block rounded-md border-l-2 border-transparent px-3 py-1.5 leading-6 text-muted transition hover:border-primary hover:bg-rose-50 hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary dark:hover:bg-rose-950/30"
                href={`#${heading.slug}`}
                data-toc-link
                data-heading-id={heading.slug}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </aside>
  )
}

<script is:inline>
  (() => {
    const initArticleToc = () => {
      const links = Array.from(document.querySelectorAll('[data-toc-link]'));
      if (!links.length) return;

      const linksById = new Map();
      links.forEach((link) => {
        const id = link.getAttribute('data-heading-id');
        if (id) linksById.set(id, link);
      });

      const headings = Array.from(linksById.keys())
        .map((id) => document.getElementById(id))
        .filter(Boolean);

      const setActive = (id) => {
        links.forEach((link) => {
          const isActive = link.getAttribute('data-heading-id') === id;
          link.toggleAttribute('data-active', isActive);
          if (isActive) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        });
      };

      if (window.location.hash) {
        setActive(window.location.hash.slice(1));
      } else if (headings[0]) {
        setActive(headings[0].id);
      }

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          if (visible[0]) setActive(visible[0].target.id);
        },
        { rootMargin: '-20% 0px -65% 0px', threshold: [0, 1] }
      );

      headings.forEach((heading) => observer.observe(heading));
    };

    initArticleToc();
    document.addEventListener('astro:page-load', initArticleToc);
  })();
</script>

<style is:global>
  .article-toc-link[data-active] {
    border-color: var(--aw-color-primary);
    background: rgb(195 7 63 / 6%);
    color: var(--aw-color-primary);
  }
</style>
