---
import { Icon } from 'astro-icon/components';

export interface Props {
  id?: string;
  placeholder?: string;
  autofocus?: boolean;
  large?: boolean;
}

const {
  id = 'site-search',
  placeholder = 'Search plans, locations, posts...',
  autofocus = false,
  large = false,
} = Astro.props;
---

<div id={id} class="site-search" data-pagefind-ignore>
  <label class="sr-only" for={`${id}-input`}>Site search</label>
  <div
    class:list={[
      'flex items-center gap-3 rounded-md border border-slate-300 bg-white shadow-sm transition focus-within:border-primary focus-within:ring-4 focus-within:ring-rose-100 dark:border-slate-700 dark:bg-slate-900 dark:focus-within:ring-rose-950/40',
      large ? 'px-4 py-3 md:px-5 md:py-4' : 'px-3 py-2',
    ]}
  >
    <Icon name="tabler:search" class:list={['shrink-0 text-primary', large ? 'h-6 w-6' : 'h-5 w-5']} />
    <input
      id={`${id}-input`}
      class:list={[
        'min-w-0 flex-1 bg-transparent text-slate-950 outline-none placeholder:text-slate-500 dark:text-white dark:placeholder:text-slate-400',
        large ? 'text-lg md:text-xl' : 'text-base',
      ]}
      type="search"
      placeholder={placeholder}
      autocomplete="off"
      spellcheck="false"
      autofocus={autofocus}
      data-search-input
    />
  </div>
  <p class="mt-3 min-h-6 text-sm text-muted" aria-live="polite" data-search-status></p>
  <div class="mt-4 grid gap-3" data-search-results></div>
</div>

<script is:inline>
  (() => {
    const script = document.currentScript;
    const root = script?.previousElementSibling;
    if (!(root instanceof HTMLElement)) return;
    if (root.dataset.searchReady === 'true') return;
    root.dataset.searchReady = 'true';

    const input = root.querySelector('[data-search-input]');
    const status = root.querySelector('[data-search-status]');
    const results = root.querySelector('[data-search-results]');
    let pagefindPromise;
    let activeSearch = 0;

    const setStatus = (message) => {
      status.textContent = message;
    };

    const escapeHtml = (value) =>
      String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');

    const normalizeUrl = (url) => {
      if (!url) return '/';
      return url.replace(/\/index\.html$/, '/').replace(/index\.html$/, '');
    };

    const loadPagefind = async () => {
      if (!pagefindPromise) {
        pagefindPromise = import('/pagefind/pagefind.js').then(async (pagefind) => {
          await pagefind.options({
            excerptLength: 28,
            highlightParam: 'highlight',
          });
          return pagefind;
        });
      }
      return pagefindPromise;
    };

    const renderResults = async (query) => {
      const searchId = ++activeSearch;
      const trimmedQuery = query.trim();

      if (!trimmedQuery) {
        results.innerHTML = '';
        setStatus('');
        return;
      }

      setStatus('Searching...');

      try {
        const pagefind = await loadPagefind();
        const search = await pagefind.search(trimmedQuery);
        if (searchId !== activeSearch) return;

        const items = await Promise.all(search.results.slice(0, 10).map((result) => result.data()));
        if (!items.length) {
          results.innerHTML = '';
          setStatus('No matching results');
          return;
        }

        results.innerHTML = items
          .map((item) => {
            const url = normalizeUrl(item.url);
            const title = item.meta?.title || url;
            const excerpt = item.excerpt || '';
            return `
              <a class="block rounded-md border border-slate-200 bg-white p-4 shadow-sm transition hover:border-primary hover:shadow-md focus:outline-none focus:ring-4 focus:ring-rose-100 dark:border-slate-700 dark:bg-slate-900 dark:hover:border-rose-300 dark:focus:ring-rose-950/40" href="${url}">
                <span class="block text-base font-semibold text-slate-950 dark:text-white">${escapeHtml(title)}</span>
                <span class="mt-2 block text-sm leading-6 text-slate-600 dark:text-slate-300">${excerpt}</span>
              </a>
            `;
          })
          .join('');
        setStatus(`Found ${search.results.length} result${search.results.length === 1 ? '' : 's'}`);
      } catch {
        results.innerHTML = '';
        setStatus('Search index is generated after build.');
      }
    };

    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q');
    if (initialQuery) {
      input.value = initialQuery;
      renderResults(initialQuery);
    }

    let timeout;
    input.addEventListener('input', () => {
      window.clearTimeout(timeout);
      timeout = window.setTimeout(() => renderResults(input.value), 120);
    });
  })();
</script>
