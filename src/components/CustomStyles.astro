---
import '@fontsource-variable/inter';

// Good alternatives for later: Literata for essays, IBM Plex Sans for a more technical voice,
// or Space Grotesk for stronger portfolio branding.
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(22 101 52);
    --aw-color-secondary: rgb(15 118 110);
    --aw-color-accent: rgb(180 83 9);

    --aw-color-text-heading: rgb(18 24 22);
    --aw-color-text-default: rgb(31 41 36);
    --aw-color-text-muted: rgb(31 41 36 / 68%);
    --aw-color-bg-page: rgb(250 250 247);

    --aw-color-bg-page-dark: rgb(18 24 22);

    ::selection {
      background-color: rgb(220 252 231);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(74 222 128);
    --aw-color-secondary: rgb(45 212 191);
    --aw-color-accent: rgb(251 191 36);

    --aw-color-text-heading: rgb(247 248 245);
    --aw-color-text-default: rgb(226 232 225);
    --aw-color-text-muted: rgb(226 232 225 / 72%);
    --aw-color-bg-page: rgb(18 24 22);

    ::selection {
      background-color: rgb(20 83 45);
      color: rgb(247 248 245);
    }
  }
</style>
