---
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About',
  description: 'About Jackie Sung and the ideas behind this VPS and vibe coding site.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="About"
    title="Practical notes for server operators."
    subtitle="This site keeps VPS plan comparisons, affiliate links, and vibe coding notes in one lightweight English reference."
    callToAction={{ text: 'Read the blog', href: '/blog', icon: 'tabler:book-2' }}
    callToAction2={{ text: 'Compare VPS plans', href: '/bandwagonhost' }}
  />

  <Content
    isReversed
    items={[
      {
        title: 'VPS comparisons',
        description: 'Readable provider pages for plans, locations, bandwidth, prices, and affiliate order links.',
      },
      {
        title: 'Vibe coding tools',
        description:
          'Notes on Codex, Claude Code, GPT, and the workflows that make AI-assisted development repeatable.',
      },
      {
        title: 'Practical publishing',
        description: 'Small, direct pages that can be updated quickly when plans or workflows change.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=1400&q=80',
      alt: 'People discussing notes and laptops at a table.',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-normal dark:text-white sm:text-3xl mb-3">A small reference site</h2>
      <p>
        Jackie Sung is built around two useful habits: compare server plans without clutter, and document vibe coding
        workflows while they are still fresh enough to improve.
      </p>
      <p class="mt-4">
        The tone is plain and practical. Each page should make it easier to pick a provider, check a plan, or improve a
        coding loop with AI tools.
      </p>
    </Fragment>
  </Content>

  <Features
    title="Publishing principles"
    subtitle="A simple filter for deciding what belongs on the site."
    columns={3}
    items={[
      {
        title: 'Current over complete',
        description: 'Provider pages should be easy to refresh instead of trying to preserve every old snapshot.',
        icon: 'tabler:filter-check',
      },
      {
        title: 'Specific over generic',
        description: 'Concrete specs, links, prompts, and tradeoffs age better than broad commentary.',
        icon: 'tabler:target-arrow',
      },
      {
        title: 'Reusable over viral',
        description: 'A post earns its place when it helps a reader solve a similar server or coding problem later.',
        icon: 'tabler:repeat',
      },
    ]}
  />

  <Features2
    title="Common paths"
    columns={3}
    items={[
      {
        title: 'New reader',
        description: 'Start with the latest posts and the server menu to understand the current direction.',
        icon: 'tabler:map',
      },
      {
        title: 'Plan correction',
        description: 'Use the Contact page for updated prices, routes, locations, or link issues.',
        icon: 'tabler:messages',
      },
      {
        title: 'Future archive',
        description: 'New provider pages and AI workflow notes can be added as clean Markdown or Astro pages.',
        icon: 'tabler:database-import',
      },
    ]}
  />
</Layout>
