---
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About',
  description: 'About Your Name and the ideas behind this personal site.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="About"
    title="I write to make useful thinking easier to reuse."
    subtitle="This is the short version of the personal site: who I am, what I am exploring, and why the archive is being rebuilt instead of copied wholesale."
    callToAction={{ text: 'Read the blog', href: '/blog', icon: 'tabler:book-2' }}
    callToAction2={{ text: 'What I am doing now', href: '/now' }}
  />

  <Content
    isReversed
    items={[
      {
        title: 'AI and practical work',
        description: 'How AI changes writing, software, learning, and the small systems that support daily output.',
      },
      {
        title: 'Software craft',
        description: 'Notes on building maintainable tools, cleaning up legacy systems, and choosing boring technology well.',
      },
      {
        title: 'Public learning',
        description: 'Publishing clear fragments before they harden into over-polished essays.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=1400&q=80',
      alt: 'People discussing notes and laptops at a table.',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-normal dark:text-white sm:text-3xl mb-3">A smaller, sharper site</h2>
      <p>
        Replace this paragraph with your real bio. Keep it direct: what you do, what you are known for, what you are
        currently learning, and what readers can expect from the writing here.
      </p>
      <p class="mt-4">
        The tone should feel personal but useful. This is not a marketing homepage; it is a durable home base for
        writing, contact, and selected work.
      </p>
    </Fragment>
  </Content>

  <Features
    title="Writing principles"
    subtitle="A simple editorial filter for deciding what belongs on the new site."
    columns={3}
    items={[
      {
        title: 'Current over complete',
        description: 'The archive should show the thinking you stand behind now, not every post you have ever published.',
        icon: 'tabler:filter-check',
      },
      {
        title: 'Specific over generic',
        description: 'Concrete decisions, examples, and tradeoffs age better than broad commentary.',
        icon: 'tabler:target-arrow',
      },
      {
        title: 'Reusable over viral',
        description: 'A post earns its place when it helps you or a reader solve a similar problem later.',
        icon: 'tabler:repeat',
      },
    ]}
  />

  <Features2
    title="Common paths"
    columns={3}
    items={[
      {
        title: 'New reader',
        description: 'Start with the latest posts and the Now page to understand the current direction.',
        icon: 'tabler:map',
      },
      {
        title: 'Collaborator',
        description: 'Use the Contact page for project ideas, questions, or introductions.',
        icon: 'tabler:messages',
      },
      {
        title: 'Future archive',
        description: 'Older WordPress posts can be imported gradually as edited, tagged Markdown files.',
        icon: 'tabler:database-import',
      },
    ]}
  />
</Layout>
