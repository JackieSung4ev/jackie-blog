---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';

const metadata = {
  title: 'Contact',
  description: 'Ways to contact JackieSung.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Send a useful note."
    subtitle="Use this page for VPS plan corrections, affiliate-link issues, AI coding topics, collaborations, and useful references."
    callToAction={{ text: 'Email hello@example.com', href: 'mailto:hello@example.com', icon: 'tabler:mail' }}
    callToAction2={{ text: 'Read the blog', href: '/blog' }}
  />

  <Features2
    title="Good reasons to reach out"
    columns={3}
    items={[
      {
        title: 'A specific question',
        description: 'A post helped, confused you, or deserves a correction.',
        icon: 'tabler:help-circle',
      },
      {
        title: 'A plan update',
        description: 'A VPS price, location, route, or affiliate link needs to be corrected.',
        icon: 'tabler:tool',
      },
      {
        title: 'A good reference',
        description: 'You found a tool, benchmark, article, or AI coding workflow worth covering.',
        icon: 'tabler:link',
      },
    ]}
  />

  <Content
    title="Useful links"
    subtitle="The fastest paths for corrections, updates, and following new notes."
    columns={2}
    items={[
      {
        title: 'Email',
        description: 'hello@example.com',
        icon: 'tabler:mail',
      },
      {
        title: 'RSS',
        description: '/rss.xml',
        icon: 'tabler:rss',
      },
      {
        title: 'BandwagonHost',
        description: '/bandwagonhost',
        icon: 'tabler:server-2',
      },
      {
        title: 'ION Krypt Cloud',
        description: '/ion-krypt-cloud',
        icon: 'tabler:cloud',
      },
    ]}
  />
</Layout>
