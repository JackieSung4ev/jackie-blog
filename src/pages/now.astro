---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: 'Now',
  description: 'A short now page for current focus areas, projects, and site housekeeping.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Now"
    title="What I am paying attention to now."
    subtitle="Updated June 2026. Current focus: VPS plan pages, affiliate link hygiene, and AI coding workflows."
    callToAction={{ text: 'Latest writing', href: '/blog', icon: 'tabler:book-2' }}
  />

  <Features
    title="Current focus"
    columns={2}
    items={[
      {
        title: 'Maintaining VPS plan pages',
        description: 'Keeping BandwagonHost and ION pages readable, current, and linked through the configured affiliate URLs.',
        icon: 'tabler:archive',
      },
      {
        title: 'AI as daily infrastructure',
        description: 'Tracking how AI changes research, editing, coding, and the way small sites should organize knowledge.',
        icon: 'tabler:sparkles',
      },
      {
        title: 'Small static pages',
        description: 'Keeping the site static, portable, and easy to version instead of depending on a heavy CMS.',
        icon: 'tabler:hammer',
      },
      {
        title: 'Better defaults for writing',
        description: 'Finding formats for essays, notes, project logs, and resource pages that are easy to keep using.',
        icon: 'tabler:layout-list',
      },
    ]}
  />

  <Content
    title="Site housekeeping"
    subtitle="The next practical steps before this becomes the permanent home page."
    items={[
      {
        title: 'Replace temporary contact details',
        description: 'Domain, email, and social URLs should be set before the site is published publicly.',
      },
      {
        title: 'Refresh provider data',
        description: 'Check prices and availability on a regular cadence so deal pages remain trustworthy.',
      },
      {
        title: 'Expand AI coding notes',
        description: 'Add compact notes when Codex, Claude Code, or GPT workflows produce reusable lessons.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1456324504439-367cee3b3c32?auto=format&fit=crop&w=1400&q=80',
      alt: 'A notebook beside a laptop during planning.',
    }}
  />

  <BlogLatestPosts title="Recently published" count={3} />
</Layout>
