---
import Layout from '~/layouts/PageLayout.astro';
import SearchBox from '~/components/SearchBox.astro';

const metadata = {
  title: 'Search',
  description: 'Search Jackie Sung pages, VPS plans, and vibe coding posts.',
  robots: {
    index: false,
    follow: true,
  },
};
---

<Layout metadata={metadata}>
  <section class="site-container py-12 lg:py-16">
    <header class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">Search</p>
      <h1 class="mt-3 text-3xl font-bold leading-tight text-slate-950 dark:text-white md:text-5xl">
        Search Jackie Sung
      </h1>
      <p class="mt-5 text-lg leading-8 text-muted">
        Search VPS plans, provider pages, vibe coding posts, locations, specs, coupons, and notes.
      </p>
    </header>

    <div class="mt-8">
      <SearchBox id="search-page" large autofocus />
    </div>
  </section>
</Layout>
