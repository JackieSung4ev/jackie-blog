---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import SearchBox from '~/components/SearchBox.astro';

const metadata = {
  title: 'Jackie Sung - Full-Stack Developer, Designer, and Indie App Builder',
  ignoreTitleTemplate: true,
  description:
    'Jackie Sung is a full-stack developer, visual designer, indie app builder, vibe coding enthusiast, and cross-border e-commerce operator.',
};
---

<Layout metadata={metadata}>
  <Hero>
    <Fragment slot="title">Jackie Sung</Fragment>

    <Fragment slot="subtitle">
      Full-stack developer, visual designer, indie app builder, vibe-coding enthusiast, and cross-border e-commerce
      operator with 10+ years in the arena. I build practical tools, chase clean interfaces, and keep notes from the
      lively overlap of code, design, apps, and business. If you love one of these things that I love, we already have
      something in common.
    </Fragment>

    <Fragment slot="content">
      <div class="mx-auto mt-8 max-w-2xl text-left">
        <SearchBox id="home-search" placeholder="Search notes, server pages, and projects..." large />
      </div>
    </Fragment>
  </Hero>
</Layout>
