---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';

const supporters = [
  { name: 'CY', amount: '￥31' },
  { name: 'Kenny', amount: '￥50' },
  { name: '亜璃子', amount: '￥10' },
  { name: '鹿大师', amount: '￥5' },
  { name: 'BYZED', amount: '￥7' },
  { name: '灿', amount: '￥7.32' },
  { name: 'DANIELRUN', amount: '￥10' },
  { name: '爱抖腿的小鸭子', amount: '￥5' },
  { name: '普嗵亾〆', amount: '￥1' },
  { name: '神风', amount: '￥8.88' },
  { name: '迷', amount: '￥0.01' },
  { name: '霍夫曼', amount: '￥101' },
  { name: '封不觉', amount: '￥3' },
  { name: '香港记者', amount: '￥6' },
  { name: '匿名捐赠者', amount: '￥2' },
  { name: '致敬电锯', amount: '￥66' },
  { name: '夜雨', amount: '￥3' },
  { name: '匿名捐赠者', amount: '￥3' },
  { name: 'DRAMA奎恩', amount: '￥10' },
  { name: '吃货家的胖墩', amount: '￥1' },
  { name: 'SOS', amount: '￥10' },
  { name: 'DRAGON JELLY', amount: '￥2.33' },
  { name: '匿名捐赠者', amount: '￥30' },
  { name: '管理员是兲', amount: '￥0.1' },
  { name: '袁大圣', amount: '￥5' },
  { name: 'RAKO', amount: '￥18.88' },
  { name: '米宸', amount: '￥5' },
  { name: '匿名捐赠者', amount: '￥1' },
  { name: '暮影微凉', amount: '￥5' },
  { name: 'JAYOMEGA', amount: '￥10' },
  { name: 'FREAK？', amount: '￥10' },
  { name: '笼.', amount: '￥5' },
];

const paymentMethods = ['Paypal', 'Alipay', 'WechatPay'];

const metadata = {
  title: 'Donate',
  description: 'Support JackieSung through Paypal, Alipay, or WechatPay, with the original donation record preserved.',
};
---

<Layout metadata={metadata}>
  <section class="bg-slate-50/80 dark:bg-slate-950">
    <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:py-16">
      <header
        class="rounded-md border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900 sm:p-8"
      >
        <p class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-primary">
          <Icon name="tabler:heart-handshake" class="h-4 w-4" />
          Support
        </p>
        <h1 class="mt-4 text-3xl font-bold leading-tight text-slate-950 dark:text-white md:text-5xl">Donate</h1>
        <p class="mt-5 max-w-3xl text-base leading-7 text-muted md:text-lg">
          If you find my blog helpful and you are willing to sponsor it, Paypal, Alipay, and WechatPay are supported.
          Each donation will be on record. Thanks to everyone who has supported me.
        </p>

        <div class="mt-7 grid gap-3 sm:grid-cols-3">
          {
            paymentMethods.map((method) => (
              <div class="rounded-md bg-rose-50 p-4 dark:bg-rose-950/30">
                <p class="flex items-center gap-2 text-sm font-semibold text-primary dark:text-rose-100">
                  <Icon name="tabler:wallet" class="h-4 w-4" />
                  {method}
                </p>
                <p class="mt-2 text-sm leading-6 text-slate-700 dark:text-slate-200">Supported on the original page.</p>
              </div>
            ))
          }
        </div>
      </header>

      <section class="mt-8">
        <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-primary">Donation record</p>
            <h2 class="text-2xl font-bold text-slate-950 dark:text-white">Supporters</h2>
          </div>
          <p class="text-sm text-muted">{supporters.length} recorded donations</p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {
            supporters.map(({ name, amount }) => (
              <article class="rounded-md border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                <h3 class="text-base font-bold text-slate-950 dark:text-white">{name}</h3>
                <p class="mt-2 font-mono text-lg font-bold text-primary">{amount}</p>
              </article>
            ))
          }
        </div>
      </section>
    </div>
  </section>
</Layout>
